{
  "name": "release branches — admins only",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ],
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/release/**/*"],
      "exclude": []
    }
  },
  "rules": [{ "type": "creation" }]
}
