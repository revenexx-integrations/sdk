{
  "name": "branch naming convention",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": ["~ALL"],
      "exclude": [
        "refs/heads/feature/**/*",
        "refs/heads/hotfix/**/*",
        "refs/heads/bugfix/**/*",
        "refs/heads/dependabot/**/*",
        "refs/heads/release/**/*"
      ]
    }
  },
  "rules": [{ "type": "creation" }]
}
