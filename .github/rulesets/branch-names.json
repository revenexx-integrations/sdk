{
  "name": "branch naming convention",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": ["~ALL"],
      "exclude": [
        "refs/heads/feature/*",
        "refs/heads/hotfix/*",
        "refs/heads/bugfix/*",
        "refs/heads/chore/*",
        "refs/heads/release/*",
        "refs/heads/changeset-release/*",
        "refs/heads/dependabot/**/*"
      ]
    }
  },
  "rules": [{ "type": "creation" }]
}
